age = 68
weekday = "Tuesday"
matinee = True

price_options = [14] 

# senior discount
if age >= 65:
    price_options.append(8)

# Tuesday deal
if weekday == "Tuesday":
    price_options.append(10)

# matinee deal
if matinee:
    if age >= 65:
        price_options.append(5)
    else:
        price_options.append(8)

final_price = min(price_options)

print("age:", age)
print("weekday:", weekday)
print("matinee:", matinee)
print("price: $", final_price)
